// bantai Slack frontend — local minislack config for interactive testing.
//
// Picked up automatically by `bantai slack` (first hit wins):
//   1. ./.bantai/slack.json       ← this file
//   2. ~/.bantai/slack.json
//   3. --slack-config <path>
//
// Relies on `bantai minislack` seeding a deterministic `bantai` app on
// boot (A00000001 on a fresh fixture, or the app rehydrated from
// workspace.json when --persist is set). Tokens below match that app.
{
  "workspace": {
    "mode": "socket",
    "slack_api_url": "http://localhost:59088",
    "bot_token": "xoxb-A00000001",
    "app_token": "xapp-A00000001"
  },

  "defaults": {
    // Real adapter — requires `codex` on PATH. Swap to "claude", "gemini",
    // "acp", or "mock" depending on what you want to exercise.
    "backend": "codex",
    "verbosity": "normal",
    "require_mention": true,
    "trigger_name": "bantai",
    "control_prefix": "!bantai",
    "session_banner": true,
    "auto_join_threads": true,

    // Bypass permission prompts so interactive multi-channel dogfooding
    // doesn't gate on Block-Kit approval flows. Flip back to "default" to
    // exercise the approver experience end-to-end.
    "permission_mode": "bypassPermissions",

    // Cost footer lights up after every turn_complete. Useful while
    // exercising a real backend — turn it off for headless scripted runs.
    "show_cost": true,

    // 0 = disabled. Flip these on when rehearsing S8 per-turn deadline /
    // budget-cap guards.
    "turn_timeout_s": 0,
    "max_budget_usd": 0,

    // Empty = anyone can approve Block-Kit prompts. Pin to specific
    // user IDs (alice=U00000001, bob=U00000002 in the `basic` fixture)
    // to exercise the approver allow-list.
    "approvers": []
  },

  // Per-channel overrides — each project mapped to a different backend +
  // model so one minislack instance can exercise three adapters at once.
  // Channel IDs come from `bantai minislack --fixture basic` plus the three
  // channels created via `conversations.create` (proj-bantai, proj-cringle-ai,
  // trip-2026-okinawa → C00000003/4/5 in fixture order).
  "channels": [
    {
      "id": "C00000003",
      "name": "proj-bantai",
      "project_dir": "/Users/odin/dev/repos/bantai",
      "backend": "claude",
      "model": "claude-opus-4-7"
    },
    {
      "id": "C00000004",
      "name": "proj-cringle-ai",
      "project_dir": "/Users/odin/dev/repos/cringle.ai",
      "model": "claude-opus-4-7"
    },
    {
      "id": "C00000005",
      "name": "trip-2026-okinawa",
      "project_dir": "/Users/odin/dev/repos/slack-agent-projects/trip-2026-okinawa",
      "backend": "gemini"
    }
  ]
}

// ---------------------------------------------------------------------------
// Driving it interactively:
//
//   # Terminal 1 — the running minislack prints the bantai tokens at boot.
//   bun run dev -- minislack --fixture basic
//
//   # Terminal 2 — bantai picks up this file from .bantai/slack.json.
//   bun run dev -- slack
//
//   # Post as alice via the SPA at http://localhost:<port>/ or curl:
//   curl -X POST http://localhost:<port>/api/chat.postMessage \
//     -H "Authorization: Bearer xoxp-U00000001" \
//     -H "Content-Type: application/json" \
//     -d '{"channel":"C00000001","text":"<@U00000003> ship it"}'
//
//   # The mention target is the bantai bot user — U00000003 after the
//   # two seeded users on a fresh `basic` boot.
// ---------------------------------------------------------------------------
