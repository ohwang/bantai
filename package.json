{
  "name": "bantai",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Open-source terminal UI for agentic coding backends (Claude Code, Codex, ACP, and more)",
  "author": "Odin Wang <ohwxyz@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohwxyz/bantai.git"
  },
  "homepage": "https://github.com/ohwxyz/bantai",
  "bugs": {
    "url": "https://github.com/ohwxyz/bantai/issues"
  },
  "bin": {
    "bantai": "./bin/bantai",
    "bantai-storybook": "./bin/bantai-storybook"
  },
  "scripts": {
    "dev": "bun run --conditions=browser ./src/index.ts",
    "dev:mock": "bun run --conditions=browser ./src/index.ts -- --backend mock",
    "test": "bun test --timeout 30000",
    "storybook": "bun run --conditions=browser ./src/storybook/index.tsx",
    "dev:storybook": "bun run --conditions=browser --watch ./src/storybook/index.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "bun run lint:opentui && tsc --noEmit",
    "lint:opentui": "bash scripts/lint-opentui.sh",
    "check:tests": "bash scripts/check-test-coverage.sh",
    "docs:check": "bash scripts/docs-check.sh",
    "version:patch": "bash scripts/bump-version.sh patch",
    "version:minor": "bash scripts/bump-version.sh minor",
    "version:major": "bash scripts/bump-version.sh major"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.120",
    "@openai/codex-sdk": "^0.125.0",
    "@opentui/core": "^0.1.100",
    "@opentui/solid": "^0.1.100",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.0",
    "commander": "^14.0.3",
    "fuzzysort": "^3.1.0",
    "jsonc-parser": "^3.3.1",
    "markdown-it": "14.1.1",
    "solid-js": "^1.9.0",
    "string-width": "^8.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@slack/types": "^2.20.1",
    "@types/bun": "^1.3.12",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^6.0.3"
  },
  "patchedDependencies": {
    "follow-redirects@1.16.0": "patches/follow-redirects@1.16.0.patch"
  }
}
